{
  "name": "star-horse-form",
  "private": false,
  "author": "l_1019@163.com",
  "version": "1.6.0",
  "type": "module",
  "description": "星马动态表单组件",
  "keywords": [
    "动态表单",
    "低代码平台",
    "lowcode",
    "dynamic-form"
  ],
  "license": "MIT",
  "homepage": "https://gitee.com/lixingyu/star-horse-form-demo.git",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lixingyu/star-horse-form-demo.git"
  },
  "main": "dist/index.es.js",
  "module": "dist/index.es.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "!src",
    "!.git",
    "!node_modules",
    "!.vite-inspect"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.es.js"
    },
    "./*": "./dist/*"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"./**/*.{jsx,ts,tsx,vue,css,scss,html}\"",
    "serve": " vite --mode development",
    "build": " vite build --mode production",
    "preview": "vite preview --mode production",
    "deploy": "vite build --mode production && node deploy.js"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.ts",
        "options": {
          "parser": "typescript"
        }
      }
    ]
  },
  "dependencies": {
    "axios": "^1.13.2",
    "css-loader": "^7.1.2",
    "element-plus": "^2.11.9",
    "flv.js": "^1.6.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "postcss": "^8.5.6",
    "sass": "^1.94.2",
    "star-horse-lowcode": "^2.8.32",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-inject": "^5.0.5",
    "@tailwindcss/vite": "^4.1.17",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitejs/plugin-vue-jsx": "^5.1.2",
    "@vue/compiler-sfc": "^3.5.25",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^16.5.0",
    "prettier": "^3.7.3",
    "rollup-plugin-bpmnlint": "^0.4.1",
    "rollup-plugin-external-globals": "^0.13.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "terser": "^5.44.1",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.2.4",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-inspect": "^11.3.3",
    "vite-plugin-progress": "^0.0.7",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vue-eslint-parser": "^10.2.0",
    "vue-facing-decorator": "^4.0.1"
  },
  "engines": {
    "node": ">=20.13.0"
  }
}
