{
  "name": "star-horse-form",
  "private": false,
  "author": "l_1019@163.com",
  "version": "2.2.3",
  "type": "module",
  "description": "星马动态表单组件",
  "keywords": [
    "动态表单",
    "低代码平台",
    "lowcode",
    "dynamic-form"
  ],
  "license": "MIT",
  "homepage": "https://gitee.com/lixingyu/star-horse-form-demo.git",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lixingyu/star-horse-form-demo.git"
  },
  "main": "dist/index.es.js",
  "module": "dist/index.es.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "!src",
    "!.git",
    "!node_modules",
    "!.vite-inspect"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.es.js"
    },
    "./*": "./dist/*"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"./**/*.{jsx,ts,tsx,vue,css,scss,html}\"",
    "serve": " vite --mode development",
    "build": " vite build --mode production",
    "preview": "vite preview --mode production",
    "deploy": "vite build --mode production && node deploy.js"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.ts",
        "options": {
          "parser": "typescript"
        }
      }
    ]
  },
  "dependencies": {
    "axios": "^1.18.1",
    "camelcase": "^9.0.0",
    "css-loader": "^7.1.4",
    "element-plus": "^2.14.2",
    "flv.js": "^1.6.2",
    "json5": "^2.2.3",
    "lodash": "^4.18.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "postcss": "^8.5.15",
    "sass": "^1.101.0",
    "sockjs-client": "^1.6.1",
    "star-horse-lowcode": "../shplugin",
    "stompjs": "^2.3.3",
    "vanilla-jsoneditor": "^3.12.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vuedraggable-es": "^4.1.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-inject": "^5.0.5",
    "@tailwindcss/vite": "^4.3.1",
    "@types/sockjs-client": "^1.5.4",
    "@types/stompjs": "^2.3.10",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@typescript/typescript6": "^6.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vue/compiler-sfc": "^3.5.39",
    "@vue/language-core": "^3.3.5",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "rollup-plugin-bpmnlint": "^0.4.1",
    "rollup-plugin-external-globals": "^0.13.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "terser": "^5.48.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-dts": "^5.0.3",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-inspect": "^11.4.1",
    "vite-plugin-progress": "^0.0.7",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vue-eslint-parser": "^10.4.1",
    "vue-facing-decorator": "^4.0.1"
  },
  "engines": {
    "node": ">=20.13.0"
  }
}
