{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "rootDir": "./src",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node", "vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false, // 必须改为 false 才能生成声明文件
    "jsx": "preserve",
    // 关闭严格模式
    "strict": false,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "noEmitOnError": false,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationDir": "dist/types",
    "emitDeclarationOnly": true,
  },
  "outDir": "dist",  // 明确指定输出目录
  "include": ["src/api/**/*", "src/assets/**/*", "src/components/**/*", "src/lang/**/*", "src/plugins/**/*", "src/router/**/*", "src/store/**/*", "src/theme/**/*", "src/utils/**/*", "src/views/**/*", "src/*.ts", "src/*.vue", "types/**/*.ts", "node_modules/unplugin-auto-import/auto-imports.d.ts"],
  "exclude": ["dist", "node_modules", "src/sample/**/*"],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
